# Supabase — optional cloud sync (accounts + saved progress).
# Copy this file to `.env` and fill in the two values from your Supabase
# project. Note the VITE_ prefix — this is a Vite app, not Next.js, so
# NEXT_PUBLIC_… vars (from Supabase's "Connect" quickstart panel) won't work
# here; use VITE_ instead, same values.
#
# Get them from: Project dashboard → green "Connect" button (top) → Project
# URL and either the "anon" or "publishable" key. Both names below are
# accepted — copy whichever one your project shows.
#
# Both are safe to ship in the frontend: they only grant access allowed by
# row-level security (see supabase/migrations/).
#
# Leave these unset and the app runs exactly as before — fully offline,
# no account, everything in localStorage. Cloud sync simply stays hidden.
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
