# Supabase — optional cloud sync (accounts + saved progress).
# Copy this file to `.env` and fill in the two values from your Supabase
# project (Dashboard → Project Settings → API). Both are safe to ship in the
# frontend: the anon key only grants access allowed by row-level security.
#
# Leave these unset and the app runs exactly as before — fully offline,
# no account, everything in localStorage. Cloud sync simply stays hidden.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
